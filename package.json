{
  "name": "@ismail-kattakath/mcp-android",
  "version": "1.0.2",
  "description": "Android Device Control — ADB + scrcpy H.264 vision streaming + fast input. 46 tools for AI agents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-android": "./dist/index.js"
  },
  "files": [
    "dist",
    "icon.png",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "changeset publish"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "android",
    "adb",
    "scrcpy",
    "automation",
    "mobile",
    "docker",
    "ai-tools",
    "claude",
    "cursor",
    "llm-tools",
    "android-automation",
    "screen-capture",
    "ui-automation"
  ],
  "author": "Ismail Kattakath <IsmailK@infin8it.ca>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismail-kattakath/mcp-android.git"
  },
  "bugs": {
    "url": "https://github.com/ismail-kattakath/mcp-android/issues"
  },
  "homepage": "https://github.com/ismail-kattakath/mcp-android#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
